{
  "private": true,
  "version": "5.0.1",
  "description": "Monorepo for react-fatless-form, react-fatless-form-web, react-fatless-form-native, and their examples.",
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach --all --exclude 'example-*' --topological run build",
    "typecheck": "yarn workspaces foreach --all --exclude 'example-*' --topological run typecheck",
    "lint": "yarn workspaces foreach --all --exclude 'example-*' run lint",
    "typecheck:examples": "yarn workspaces foreach --all --include 'example-*' run typecheck",
    "test": "yarn workspaces foreach --all --exclude 'example-*' run test",
    "test:coverage": "yarn workspaces foreach --all --exclude 'example-*' run test:coverage"
  },
  "resolutions": {
    "@types/react": "^18.3.0",
    "react-fatless-form/react": "18.2.0",
    "react-fatless-form/react-dom": "18.2.0",
    "react-fatless-form-web/react": "18.2.0",
    "react-fatless-form-web/react-dom": "18.2.0",
    "react-fatless-form-native/react": "18.2.0",
    "react-fatless-form-native/react-dom": "18.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.3",
    "typescript": "^5.4.0",
    "yup": "^1.4.0"
  },
  "license": "MIT"
}
