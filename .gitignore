# Yarn, node-modules linker - see .yarnrc.yml and the root README's Tooling
# section for why node-modules rather than Plug'n'Play (React Native/Expo
# doesn't support PnP).
.yarn/*
!.yarn/cache
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# .yarn/cache (committed, above) holds the zipped dependency archives;
# node_modules itself is what `yarn install` materializes FROM that cache,
# and is never committed - same rule as any node_modules-linked project.
node_modules

# Build output
dist

# Native
.expo
*.tsbuildinfo

.DS_Store
