{
  "name": "example-native",
  "private": true,
  "version": "0.1.0",
  "description": "Signup form example using react-fatless-form-native and react-native-paper.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "build:deps": "yarn workspace react-fatless-form run build && yarn workspace react-fatless-form-native run build",
    "prestart": "yarn build:deps",
    "preandroid": "yarn build:deps",
    "preios": "yarn build:deps",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "expo": "~51.0.0",
    "react": "18.2.0",
    "react-fatless-form-native": "workspace:*",
    "react-native": "0.74.5",
    "react-native-paper": "^5.12.0",
    "react-native-safe-area-context": "^4.10.0",
    "react-native-vector-icons": "^10.1.0",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.6",
    "typescript": "^5.4.0"
  }
}
