{
  "name": "react-fatless-form-web",
  "version": "0.1.1",
  "description": "Web (DOM) bindings for react-fatless-form - useTextField, useNumberField, useCheckboxField, and useFormSubmit, each wired for plain HTML elements. Re-exports the entire core API, so this is the only package a web app needs to import from.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "prepack": "cp ../../LICENSE ./ && node ../../scripts/rewrite-readme-links.js prepare",
    "postpack": "node ../../scripts/rewrite-readme-links.js restore && rm -f LICENSE",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oneadera/react-fatless-form.git",
    "directory": "packages/web"
  },
  "author": "Adera Henry <oneadera@gmail.com> (https://www.linkedin.com/in/aderahenry/)",
  "bugs": {
    "url": "https://github.com/oneadera/react-fatless-form/issues"
  },
  "homepage": "https://github.com/oneadera/react-fatless-form/tree/main/packages/web#readme",
  "dependencies": {
    "react-fatless-form": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "react",
    "form",
    "forms",
    "web",
    "dom",
    "html-form",
    "form-bindings",
    "controlled-input",
    "text-input",
    "number-input",
    "checkbox",
    "checkbox-group",
    "select",
    "multi-select",
    "file-upload",
    "form-submit",
    "useTextField",
    "useCheckboxField",
    "useSelectField",
    "useFileField",
    "react-form-web",
    "form-library",
    "form-validation",
    "yup",
    "typescript",
    "headless",
    "form-hooks",
    "input-bindings",
    "form-management"
  ],
  "license": "MIT"
}
