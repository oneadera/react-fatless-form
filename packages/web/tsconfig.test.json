{
  // Not used by `build`, `typecheck`, or `test` - see
  // packages/core/tsconfig.test.json for the full rationale. Repeats this
  // package's own path mapping (react-fatless-form → core/src) so editors
  // resolve the workspace import correctly inside __tests__/ too.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "react-fatless-form": ["../core/src/index.ts"]
    },
    "types": ["jest"]
  },
  "include": ["src", "__tests__"]
}
